# HTTP/HTTPS Gateway (.htaccess)
# Disable automatic HTTP -> HTTPS redirection for this specific folder
# so IoT devices without SSL support can still send data.

RewriteEngine On

# Stop processing rewrite rules from parent directories
RewriteOptions InheritDownBefore

# Force hostinger to not redirect HTTP to HTTPS in this directory
<IfModule mod_rewrite.c>
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ - [ENV=HTTPS:off]
</IfModule>

# If Hostinger's edge server specifically is forcing the redirect via an 'HTTPS: on' environment variable:
SetEnvIf Request_URI "^/backend-spc/device/gateway/api/v1/live_location\.php$" HTTPS=off

# Clear HSTS header if it was being set
<IfModule mod_headers.c>
    Header always unset Strict-Transport-Security
</IfModule>

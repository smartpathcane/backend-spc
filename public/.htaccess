# SmartPath Cane - Public Directory .htaccess
# CORS Configuration for API endpoints

# Enable rewrite engine
RewriteEngine On

# CORS Headers - Set for ALL requests
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "https://smartpath-cane.netlify.app"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
    Header always set Access-Control-Allow-Credentials "true"
    Header always set Access-Control-Max-Age "86400"
</IfModule>

# Handle CORS preflight OPTIONS request - return 200 immediately
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^ - [R=200,L]

# Rewrite all requests to index.php (API routing)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# PHP settings
php_value display_errors 0
php_value log_errors 1

# SmartPath Cane - Public Directory (.htaccess)
# CORS is handled only in PHP (bootstrap/middleware/cors.php) so the response has a
# single Access-Control-Allow-Origin that matches the browser's Origin. Duplicate or
# wrong fixed origins here break fetch() from Netlify (maintenance /api/status, auth, etc.).

RewriteEngine On

# Route API paths to index.php (no static files matched)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

php_value display_errors 0
php_value log_errors 1
